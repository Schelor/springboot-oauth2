spring:
  application:
    name: demogradle

server:
  port: 9000

  # 1. H2 内存数据库配置
  datasource:
    url: jdbc:h2:mem:auth_db
    driver-class-name: org.h2.Driver
    username: sa
    password:
  # 开启 H2 控制台（启动后可通过 http://localhost:9000/h2-console 访问）
  h2:
    console:
      enabled: true
      path: /h2-console
      settings:
        web-allow-others: true # H2 自带的安全拦截/403

  # 2. JPA & Hibernate 配置
  jpa:
    hibernate:
      ddl-auto: update # 自动建表
    show-sql: true
    # Spring Boot 会自动识别 H2 方言，这里不需要显式指定 dialect 了